# Mailchimp Configuration
# Get these values from your Mailchimp account:
# 1. Go to https://us13.admin.mailchimp.com/account/api/
# 2. Click "Create A Key" to generate an API key
# 3. The server prefix is the part after the dash in your API key (e.g., "us13")
# 4. Find your Audience ID: Audience → Manage Audience → Settings → Audience name and defaults

MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_SERVER_PREFIX=us13
MAILCHIMP_AUDIENCE_ID=your_audience_id_here

# Resend Email Configuration (for dealer applications)
RESEND_API_KEY=your_resend_api_key_here
