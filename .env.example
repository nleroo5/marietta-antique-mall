# Marietta Antique Mall - Environment Variables
# Copy this file to .env.local for local development

# ===================================
# EMAIL SERVICE (REQUIRED)
# ===================================
# Resend API Key for email functionality
# Get your API key from: https://resend.com/api-keys
# This is REQUIRED for the vendor application form to work
RESEND_API_KEY=re_your_api_key_here

# ===================================
# NEXT.JS CONFIGURATION
# ===================================
# Environment type (automatically set by hosting platform)
NODE_ENV=production

# ===================================
# NOTES FOR DEPLOYMENT
# ===================================
#
# Vercel Deployment:
# 1. Add RESEND_API_KEY in Vercel Dashboard → Settings → Environment Variables
# 2. Set for: Production, Preview, Development
# 3. Redeploy after adding variables
#
# Local Development:
# 1. Copy this file to .env.local
# 2. Add your actual RESEND_API_KEY
# 3. Never commit .env.local to git
#
# Testing Without API Key:
# - The application will build successfully even without RESEND_API_KEY
# - The vendor form will show a friendly error message prompting users to call instead
# - All other site functionality works normally
