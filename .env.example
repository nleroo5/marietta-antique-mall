# Marietta Antique Mall - Environment Variables
# Copy this file to .env.local for local development

# ===================================
# EMAIL SERVICE (REQUIRED)
# ===================================
# Resend API Key for email functionality
# Get your API key from: https://resend.com/api-keys
# This is REQUIRED for the vendor application form AND the Sell/Donate form
RESEND_API_KEY=re_your_api_key_here

# ===================================
# SELL / DONATE FORM
# ===================================
# Inbox that receives "Sell or Donate" item leads.
# Defaults to contactus@mariettaantiquemall.com if unset.
MARIETTA_INBOX=contactus@mariettaantiquemall.com

# Verified Resend sender for the Sell/Donate form. MUST be on a Resend-verified
# domain (mariettaantiquemall.com). A gmail.com address will NOT work.
# Defaults to "Marietta Antique Mall <sell@mariettaantiquemall.com>" if unset.
MAIL_FROM=Marietta Antique Mall <sell@mariettaantiquemall.com>

# Vercel Blob read/write token for photo uploads. Auto-provided when Blob is
# enabled on the Vercel project; pull locally with `vercel env pull`.
# REQUIRED for photo uploads to work.
BLOB_READ_WRITE_TOKEN=

# ===================================
# RATE LIMITING (OPTIONAL)
# ===================================
# Upstash Redis for API rate limiting. If unset, rate limiting is skipped
# (graceful no-op) and all requests are allowed. Recommended for production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===================================
# NEXT.JS CONFIGURATION
# ===================================
# Environment type (automatically set by hosting platform)
NODE_ENV=production

# ===================================
# NOTES FOR DEPLOYMENT
# ===================================
#
# Vercel Deployment:
# 1. Add RESEND_API_KEY in Vercel Dashboard → Settings → Environment Variables
# 2. Set for: Production, Preview, Development
# 3. Redeploy after adding variables
#
# Local Development:
# 1. Copy this file to .env.local
# 2. Add your actual RESEND_API_KEY
# 3. Never commit .env.local to git
#
# Testing Without API Key:
# - The application will build successfully even without RESEND_API_KEY
# - The vendor form will show a friendly error message prompting users to call instead
# - All other site functionality works normally
